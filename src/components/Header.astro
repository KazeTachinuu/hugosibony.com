---
import { Icon } from 'astro-icon/components';
import LangToggle from './LangToggle.astro';

const { pathname } = Astro.url;

const CATEGORIES = [
  { name: 'Blog', href: '/blog/', icon: 'lucide:pencil' },
  { name: 'Writeups', href: '/writeups/', icon: 'lucide:file-text' },
];

const GOODIES = [
  { name: 'Portfolio', href: '/portfolio/', icon: 'lucide:layout-grid' },
  { name: 'Snippets', href: '/snippets/', icon: 'lucide:code' },
  { name: 'Reverse Shell Generator', href: '/tools/revshells/', icon: 'lucide:square-terminal' },
  { name: 'Assembly Lookup', href: '/tools/asm-lookup/', icon: 'lucide:cpu' },
  { name: 'Glossary', href: '/tools/glossary/', icon: 'lucide:book-open' },
  { name: 'Copy-Paste Tool', href: 'https://copy-paste-epita.vercel.app/', icon: 'lucide:external-link', external: true },
  { name: 'Skyjo Tracker', href: 'https://skyjo-track.vercel.app/', icon: 'lucide:external-link', external: true },
];

function isActive(href: string) {
  return pathname === href || (href !== '/' && pathname.startsWith(href));
}
---

<header class="site-header">
  <nav class="header-inner">
    <a href="/" class="brand-logo">
      <span class="brand-name">hugo</span>
      <span class="brand-spark" aria-hidden="true">✦</span>
      <span class="brand-name">sibony</span>
    </a>

    <div class="header-nav">
      {/* Categories dropdown */}
      <div class="nav-dropdown" data-dropdown>
        <button
          type="button"
          class:list={['nav-link', (isActive('/blog/') || isActive('/writeups/')) && 'nav-link-active']}
          data-dropdown-trigger
        >
          <Icon name="lucide:folder" class="nav-link-icon" size={15} />
          Categories
        </button>
        <div class="dropdown-panel" data-dropdown-panel>
          <div class="dropdown-arrow"></div>
          <div class="dropdown-list">
            {CATEGORIES.map(({ name, href, icon }) => (
              <a href={href} class="dropdown-item">
                <Icon name={icon} class="dropdown-icon" size={14} />
                <span>{name}</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      {/* Goodies dropdown */}
      <div class="nav-dropdown" data-dropdown>
        <button
          type="button"
          class:list={['nav-link', (isActive('/snippets/') || isActive('/portfolio/')) && 'nav-link-active']}
          data-dropdown-trigger
        >
          <Icon name="lucide:sparkles" class="nav-link-icon" size={15} />
          Goodies
        </button>
        <div class="dropdown-panel" data-dropdown-panel>
          <div class="dropdown-arrow"></div>
          <div class="dropdown-list">
            {GOODIES.map((item) => (
              <a href={item.href} class="dropdown-item" target={item.external ? '_blank' : undefined} rel={item.external ? 'noopener' : undefined}>
                <Icon name={item.icon} class="dropdown-icon" size={14} />
                <span>{item.name}</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      {/* Bookmarks - direct link */}
      <a href="/bookmarks/" class:list={['nav-link', isActive('/bookmarks/') && 'nav-link-active']}>
        <Icon name="lucide:bookmark" class="nav-link-icon" size={15} />
        Bookmarks
      </a>

      {/* About - direct link */}
      <a href="/about/" class:list={['nav-link', isActive('/about/') && 'nav-link-active']}>
        <Icon name="lucide:terminal" class="nav-link-icon" size={15} />
        whoami
      </a>
    </div>

    <div class="header-actions">
      <LangToggle langs={['en', 'fr']} default="en" storageKey="site-lang" />
      <a href="/search/" aria-label="Search" title="Search (Ctrl+K or /)" class="icon-btn hidden sm:inline-flex">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      </a>
      <button type="button" data-theme-toggle aria-label="Toggle theme" class="icon-btn">
        <svg data-theme-icon="moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="dark:hidden"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <svg data-theme-icon="sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden dark:block"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
      </button>
      <a href="/rss.xml" class="icon-btn hidden sm:inline-flex" aria-label="RSS feed">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
      </a>
      <button type="button" data-mobile-toggle aria-label="Toggle menu" class="icon-btn sm:hidden">
        <svg data-menu-icon="open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 8h16M4 16h16"/></svg>
        <svg data-menu-icon="close" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="hidden"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </div>
  </nav>

  {/* Mobile nav drawer */}
  <div data-mobile-nav class="mobile-nav hidden sm:hidden">
    <div class="px-6 py-4 flex flex-col gap-1">
      <p class="label mt-2 mb-1 px-3">Categories</p>
      {CATEGORIES.map(({ name, href }) => (
        <a href={href} class:list={['mobile-nav-link', isActive(href) && 'mobile-nav-link-active']}>
          {name}
        </a>
      ))}
      <p class="label mt-4 mb-1 px-3">Goodies</p>
      {GOODIES.map((item) => (
        <a href={item.href} class:list={['mobile-nav-link', isActive(item.href) && 'mobile-nav-link-active']} target={item.external ? '_blank' : undefined} rel={item.external ? 'noopener' : undefined}>
          {item.name}{item.external ? ' ↗' : ''}
        </a>
      ))}
      <a href="/bookmarks/" class:list={['mobile-nav-link mt-2 border-t border-theme pt-3', isActive('/bookmarks/') && 'mobile-nav-link-active']}>
        Bookmarks
      </a>
      <a href="/about/" class:list={['mobile-nav-link', isActive('/about/') && 'mobile-nav-link-active']}>
        whoami
      </a>
      <a href="/search/" class="mobile-nav-link mt-2 border-t border-theme pt-3">
        Search
      </a>
    </div>
  </div>
</header>

<script>
  const toggle = document.querySelector('[data-mobile-toggle]');
  const mobileNav = document.querySelector('[data-mobile-nav]');
  const openIcon = document.querySelector('[data-menu-icon="open"]');
  const closeIcon = document.querySelector('[data-menu-icon="close"]');

  function closeNav() {
    mobileNav?.classList.add('hidden');
    openIcon?.classList.remove('hidden');
    closeIcon?.classList.add('hidden');
  }

  toggle?.addEventListener('click', () => {
    const open = mobileNav?.classList.toggle('hidden');
    openIcon?.classList.toggle('hidden', !open);
    closeIcon?.classList.toggle('hidden', open ?? true);
  });
  mobileNav?.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeNav));

  // Dropdown menus
  const dropdowns = document.querySelectorAll<HTMLElement>('[data-dropdown]');

  function closeAllDropdowns() {
    dropdowns.forEach((d) => d.classList.remove('dropdown-open'));
  }

  dropdowns.forEach((dropdown) => {
    const trigger = dropdown.querySelector('[data-dropdown-trigger]');
    trigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      const wasOpen = dropdown.classList.contains('dropdown-open');
      closeAllDropdowns();
      if (!wasOpen) dropdown.classList.add('dropdown-open');
    });
  });

  document.addEventListener('click', closeAllDropdowns);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeAllDropdowns();
      if (!mobileNav?.classList.contains('hidden')) closeNav();
    }
  });
</script>
