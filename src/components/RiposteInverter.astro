---
/*
  RIPOSTE inverter. Paste the server's real "RIPOSTE ..." line (or build one with
  the buttons); the counter to send back (invert each move, reverse the order)
  updates live. Copy hands you the moves. Same logic as the solver.
*/
---

<div class="rp not-prose" data-rp>
  <span class="rp-eyebrow">riposte / contre en direct</span>

  <div class="rp-io">
    <input class="rp-input" data-rp-input spellcheck="false" autocomplete="off" placeholder="RIPOSTE U2 R' R" />
    <div class="rp-presets" data-rp-presets>
      <button class="rp-preset" type="button" data-rp-preset="U2 R' R">U2 R' R</button>
      <button class="rp-preset" type="button" data-rp-preset="L' F">L' F</button>
      <button class="rp-preset" type="button" data-rp-preset="U' F2 D">U' F2 D</button>
    </div>
  </div>

  <div class="rp-builder">
    <div class="rp-mods" data-rp-mods>
      <button class="rp-mod" type="button" data-rp-mod="" data-active>x</button>
      <button class="rp-mod" type="button" data-rp-mod="'">x'</button>
      <button class="rp-mod" type="button" data-rp-mod="2">x2</button>
    </div>
    <div class="rp-faces">
      {['U', 'R', 'F', 'D', 'L', 'B'].map((f) => (
        <button class="rp-face" type="button" data-rp-face={f}>{f}</button>
      ))}
    </div>
    <div class="rp-edit">
      <button class="rp-icon-btn" type="button" data-rp-back>suppr</button>
      <button class="rp-icon-btn" type="button" data-rp-clear>effacer</button>
    </div>
  </div>

  <div class="rp-flow">
    <div class="rp-row">
      <span class="rp-label">riposte</span>
      <div class="rp-chips" data-rp-in></div>
    </div>
    <div class="rp-rule">inverser chaque coup, puis inverser l'ordre</div>
    <div class="rp-row">
      <span class="rp-label rp-label-out">contre</span>
      <div class="rp-chips" data-rp-out></div>
      <button class="rp-copy" type="button" data-rp-copy hidden>copier</button>
    </div>
  </div>
</div>

<style is:global>
  .rp {
    margin: 2rem 0; border: 1px solid var(--border); background: var(--code-bg);
    padding: 1.2rem; font-size: 0.82rem;
    font-family: var(--font-mono, ui-monospace, monospace);
  }
  .rp * { border-radius: 0; }
  .rp-eyebrow { display: block; font-size: 0.64rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent); margin-bottom: 1rem; }

  .rp-io { display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; margin-bottom: 0.7rem; }
  .rp-input {
    flex: 1; min-width: 190px; font-family: inherit; font-size: 0.85rem; color: inherit;
    background: color-mix(in oklch, var(--page-text) 4%, transparent);
    border: 1px solid var(--border); padding: 0.5rem 0.7rem;
  }
  .rp-input:focus { outline: none; border-color: var(--accent); }
  .rp-input.rp-invalid { border-color: color-mix(in oklch, #ef4444 55%, var(--border)); }

  .rp-presets, .rp-faces { display: flex; gap: 4px; }
  .rp-preset, .rp-mod, .rp-face, .rp-icon-btn {
    font: inherit; cursor: pointer; border: 1px solid var(--border); background: none; color: inherit;
    transition: background 0.14s ease, border-color 0.14s ease, color 0.14s ease;
  }
  .rp-preset { font-size: 0.72rem; padding: 0.3rem 0.6rem; }
  .rp-preset:hover { border-color: var(--accent); }

  .rp-builder { display: flex; align-items: center; gap: 0.8rem; flex-wrap: wrap; padding: 0.7rem 0.8rem; margin: 0 0 1.2rem; border: 1px solid var(--border); }
  .rp-mods { display: inline-flex; }
  .rp-mod { font-size: 0.75rem; padding: 0.32rem 0.55rem; border-right: 0; }
  .rp-mod:last-child { border-right: 1px solid var(--border); }
  .rp-mod[data-active] { background: var(--accent); border-color: var(--accent); color: #fff; }
  .rp-face { font-size: 0.9rem; font-weight: 600; width: 40px; height: 40px; }
  .rp-face:hover { border-color: var(--accent); background: color-mix(in oklch, var(--accent) 14%, transparent); }
  .rp-edit { display: flex; gap: 4px; margin-left: auto; }
  .rp-icon-btn { font-size: 0.72rem; padding: 0.32rem 0.6rem; text-transform: uppercase; letter-spacing: 0.04em; opacity: 0.75; }
  .rp-icon-btn:hover { border-color: var(--accent); opacity: 1; }

  .rp-flow { display: flex; flex-direction: column; gap: 0.5rem; }
  .rp-row { display: flex; align-items: center; gap: 0.85rem; min-height: 40px; }
  .rp-label { font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase; width: 62px; flex: none; text-align: right; opacity: 0.55; }
  .rp-label-out { color: var(--accent); opacity: 1; }
  .rp-chips { display: flex; gap: 5px; flex-wrap: wrap; min-height: 32px; align-items: center; }
  .rp-chip { font-size: 0.85rem; font-weight: 600; padding: 0.3rem 0.55rem; border: 1px solid var(--border); }
  .rp-chip-out { border-color: var(--accent); background: color-mix(in oklch, var(--accent) 14%, transparent); color: var(--accent); }
  .rp-chip-new { animation: rp-pop 0.28s ease; }
  @keyframes rp-pop { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: none; } }
  .rp-empty { font-size: 0.76rem; opacity: 0.35; }

  .rp-rule { padding-left: 78px; font-size: 0.66rem; letter-spacing: 0.06em; text-transform: uppercase; opacity: 0.45; }

  .rp-copy { font: inherit; font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.04em; cursor: pointer; padding: 0.28rem 0.6rem; border: 1px solid var(--accent); background: none; color: var(--accent); transition: background 0.14s ease; }
  .rp-copy:hover { background: color-mix(in oklch, var(--accent) 12%, transparent); }
  .rp-copy[hidden] { display: none; }

  @media (max-width: 560px) { .rp-edit { margin-left: 0; } .rp-rule { padding-left: 0; } }
  @media (prefers-reduced-motion: reduce) { .rp-chip-new { animation: none; } }
</style>

<script>
  const MOVE = /^[URFDLB][2']?$/;
  const invert = (m: string) => (m.endsWith("'") ? m[0] : m.endsWith('2') ? m : m + "'");

  document.querySelectorAll<HTMLElement>('[data-rp]').forEach((root) => {
    const inputEl = root.querySelector<HTMLInputElement>('[data-rp-input]')!;
    const inEl = root.querySelector<HTMLElement>('[data-rp-in]')!;
    const outEl = root.querySelector<HTMLElement>('[data-rp-out]')!;
    const copyEl = root.querySelector<HTMLButtonElement>('[data-rp-copy]')!;
    let mod = '';

    const parse = () => inputEl.value.replace(/^\s*RIPOSTE\s*/i, '').trim().split(/\s+/).filter(Boolean);

    function chips(el: HTMLElement, moves: string[], out: boolean, animateLast = false) {
      if (!moves.length) { el.innerHTML = `<span class="rp-empty">${out ? "le contre apparaît ici" : ''}</span>`; return; }
      el.innerHTML = moves.map((m, i) => `<span class="rp-chip${out ? ' rp-chip-out' : ''}${animateLast && i === moves.length - 1 ? ' rp-chip-new' : ''}">${m}</span>`).join('');
    }

    function render(animateLast = false) {
      const moves = parse();
      const valid = moves.every((m) => MOVE.test(m));
      inputEl.classList.toggle('rp-invalid', moves.length > 0 && !valid);
      chips(inEl, moves, false, animateLast);
      const counter = valid ? moves.slice().reverse().map(invert) : [];
      chips(outEl, counter, true);
      copyEl.hidden = counter.length === 0;
      copyEl.textContent = 'copier';
    }

    inputEl.addEventListener('input', () => render());
    root.querySelectorAll<HTMLElement>('.rp-mod').forEach((b) => {
      b.addEventListener('click', () => { root.querySelectorAll('.rp-mod').forEach((x) => x.removeAttribute('data-active')); b.setAttribute('data-active', ''); mod = b.dataset.rpMod ?? ''; });
    });
    root.querySelectorAll<HTMLElement>('.rp-face').forEach((b) => {
      b.addEventListener('click', () => { inputEl.value = (inputEl.value.replace(/^\s*RIPOSTE\s*/i, '').trim() + ' ' + b.dataset.rpFace + mod).trim(); render(true); });
    });
    root.querySelector('[data-rp-back]')!.addEventListener('click', () => { inputEl.value = parse().slice(0, -1).join(' '); render(); });
    root.querySelector('[data-rp-clear]')!.addEventListener('click', () => { inputEl.value = ''; render(); });
    root.querySelectorAll<HTMLElement>('.rp-preset').forEach((b) => {
      b.addEventListener('click', () => { inputEl.value = b.dataset.rpPreset ?? ''; render(true); });
    });
    copyEl.addEventListener('click', () => {
      const counter = parse().slice().reverse().map(invert).join(' ');
      navigator.clipboard?.writeText(counter).then(() => { copyEl.textContent = 'copié'; setTimeout(() => (copyEl.textContent = 'copier'), 1400); });
    });

    inputEl.value = "RIPOSTE U2 R' R";
    render();
  });
</script>
