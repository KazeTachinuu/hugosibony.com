---
import { Icon } from 'astro-icon/components';

interface Row {
  label: string;
  value: string;
  kind?: 'select' | 'input' | 'password' | 'check';
}

interface Props {
  title: string;
  subtitle?: string;
  rows: Row[];
  button?: string;
}

const { title, subtitle, rows, button } = Astro.props;
---

<figure class="ui-dialog" role="img" aria-label={`${title} settings dialog`}>
  <div class="ui-dialog-bar">
    <span class="ui-dialog-dot" />
    <span class="ui-dialog-dot" />
    <span class="ui-dialog-dot" />
    <span class="ui-dialog-title">{title}</span>
  </div>
  {subtitle && <p class="ui-dialog-subtitle">{subtitle}</p>}
  <div class="ui-dialog-rows">
    {rows.map((row) => (
      <div class="ui-dialog-row">
        <span class="ui-dialog-label">{row.label}</span>
        {row.kind === 'check' ? (
          <span class="ui-dialog-check">
            <span class="ui-dialog-checkbox"><Icon name="lucide:check" size={12} /></span>
            {row.value}
          </span>
        ) : (
          <span class:list={['ui-dialog-field', row.kind === 'select' && 'ui-dialog-field-select']}>
            {row.kind === 'password' ? '•'.repeat(12) : row.value}
            {row.kind === 'select' && <Icon name="lucide:chevron-down" size={14} />}
          </span>
        )}
      </div>
    ))}
  </div>
  {button && (
    <div class="ui-dialog-actions">
      <span class="ui-dialog-button">{button}</span>
    </div>
  )}
</figure>

<style>
  .ui-dialog {
    max-width: 32rem;
    margin: 2rem auto;
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    background: var(--page-bg);
    box-shadow: 0 8px 30px -12px rgba(0, 0, 0, 0.2);
    overflow: hidden;
  }

  .ui-dialog-bar {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.75rem 1.25rem;
    border-bottom: 1px solid var(--border);
    background: var(--subtle-bg);
  }

  .ui-dialog-dot {
    width: 0.625rem;
    height: 0.625rem;
    border-radius: 50%;
    background: var(--border);
  }

  .ui-dialog-title {
    margin-left: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .ui-dialog-subtitle {
    margin: 1rem 1.75rem 0;
    font-size: 0.875rem;
    color: var(--muted);
  }

  .ui-dialog-rows {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    padding: 1.5rem 1.75rem;
  }

  .ui-dialog-row {
    display: grid;
    grid-template-columns: 42% 1fr;
    align-items: center;
    gap: 0.75rem;
  }

  .ui-dialog-label {
    font-size: 0.9375rem;
    color: var(--text-secondary);
  }

  .ui-dialog-field {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    font-size: 0.9375rem;
    font-family: var(--font-mono, ui-monospace, monospace);
    color: var(--page-text);
    background: var(--page-bg);
    min-height: 2.5rem;
    overflow-wrap: anywhere;
  }

  .ui-dialog-field-select {
    font-family: inherit;
  }

  .ui-dialog-field :global(svg) {
    flex-shrink: 0;
    color: var(--muted);
  }

  .ui-dialog-check {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    color: var(--page-text);
  }

  .ui-dialog-checkbox {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.125rem;
    height: 1.125rem;
    border-radius: 0.25rem;
    background: var(--accent);
    color: var(--page-bg);
    flex-shrink: 0;
  }

  .ui-dialog-actions {
    display: flex;
    justify-content: flex-end;
    padding: 0 1.75rem 1.25rem;
  }

  .ui-dialog-button {
    padding: 0.5rem 1.5rem;
    border-radius: 999px;
    font-size: 0.9375rem;
    font-weight: 500;
    background: var(--accent);
    color: var(--page-bg);
  }
</style>
