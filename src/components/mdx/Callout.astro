---
import { Icon } from 'astro-icon/components';

interface Props {
  type?: 'info' | 'note' | 'warn' | 'success' | 'tip' | 'error' | 'danger';
  title?: string;
}
const { type = 'note', title } = Astro.props;

const iconName: Record<string, string> = {
  info: 'lucide:info',
  note: 'lucide:pencil',
  warn: 'lucide:triangle-alert',
  success: 'lucide:check',
  tip: 'lucide:lightbulb',
  error: 'lucide:circle-alert',
  danger: 'lucide:octagon-alert',
};

// Generate a slug from title for anchor links
function slugify(text: string): string {
  return text
    .toLowerCase()
    .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/(^-|-$)/g, '');
}

const slug = title ? slugify(title) : undefined;
---

<aside class={`jh-callout jh-callout-${type}`}>
  <div class="jh-callout-icon" aria-hidden="true"><Icon name={iconName[type] ?? 'lucide:info'} size={17} /></div>
  <div class="jh-callout-body">
    {title && <h3 class="jh-callout-title" id={slug}>{title}</h3>}
    <slot />
  </div>
</aside>
