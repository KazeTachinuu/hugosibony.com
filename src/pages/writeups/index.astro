---
import Layout from '~/layouts/Layout.astro';
import PageHeader from '~/components/PageHeader.astro';
import WriteupTree from '~/components/WriteupTree.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('writeups', (e) => import.meta.env.DEV || !e.data.draft);
const challenges = all.filter((w) => w.data.cat === 'chal');
const solved = challenges.filter((w) => w.data.solved).length;
const total = challenges.length;

// Browse-by-CTF: one entry per top-level group, most challenges first.
const ctfMap = new Map<string, { name: string; count: number }>();
for (const w of challenges) {
  const key = w.id.split('/')[0];
  const name = w.data.ctf ?? key;
  const e = ctfMap.get(key) ?? { name, count: 0 };
  e.count++;
  ctfMap.set(key, e);
}
const ctfList = [...ctfMap.entries()].map(([key, v]) => ({ key, ...v })).sort((a, b) => b.count - a.count);
const ctfs = ctfList.length;
---

<Layout title="Writeups" mainClass="max-w-5xl mx-auto px-6 py-16">
  <PageHeader
    title="Writeups"
    section="writeups"
    description={`${solved} challenges solved across ${ctfs} CTFs`}
  />

  <nav class="wu-ctf-nav" aria-label="Browse by CTF">
    {ctfList.map((c) => (
      <a href={`/writeups/${c.key}/`} class="wu-ctf-link">
        {c.name}<span class="wu-ctf-count">{c.count}</span>
      </a>
    ))}
  </nav>

  <WriteupTree entries={all} />
</Layout>

<style>
  .wu-ctf-nav { display: flex; flex-wrap: wrap; gap: 0.5rem; margin: 0 0 2rem; }
  .wu-ctf-link {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.4rem 0.8rem; border-radius: 10px;
    border: 1px solid var(--border); text-decoration: none;
    font-size: 0.85rem; color: var(--page-text);
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .wu-ctf-link:hover { border-color: var(--accent); color: var(--accent); }
  .wu-ctf-count {
    font-family: var(--font-mono, ui-monospace, monospace); font-size: 0.7rem;
    padding: 0.05rem 0.4rem; border-radius: 99px;
    background: color-mix(in oklch, var(--accent) 12%, transparent); color: var(--accent);
  }
</style>
